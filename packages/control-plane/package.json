{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ai-sidekicks/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Collaboration Control Plane services and shared-session coordination logic.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sidekicks/contracts": "workspace:*",
    "@trpc/server": "^11.17.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/pg": "^8.15.6",
    "eslint": "^10.2.1",
    "typescript": "^5.9.3",
    "vitest": "catalog:testing",
    "wrangler": "^4.86.0"
  }
}
