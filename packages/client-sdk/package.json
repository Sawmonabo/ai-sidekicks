{
  "name": "@ai-sidekicks/client-sdk",
  "version": "0.0.0",
  "type": "module",
  "description": "Typed client SDK used by desktop renderer and CLI.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-sidekicks/contracts": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sidekicks/control-plane": "workspace:*",
    "@trpc/server": "^11.17.0",
    "vitest": "catalog:testing"
  }
}
