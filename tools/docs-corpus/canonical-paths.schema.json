{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-sidekicks/docs-corpus/canonical-paths.schema.json",
  "title": "Canonical-paths registry",
  "description": "Registry of canonical-vs-deprecated path strings used by path-canonical-ripple.ts. When a path is renamed/moved/canonicalized, add an entry here so the hook flags every surviving deprecated occurrence in the configured scope. The registry is the bookkeeping; the hook just enforces.",
  "type": "object",
  "additionalProperties": false,
  "required": ["paths"],
  "properties": {
    "$schema": { "type": "string" },
    "rationale": { "type": "string" },
    "paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical", "deprecated"],
        "properties": {
          "canonical": { "type": "string", "minLength": 1 },
          "deprecated": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "introduced": { "type": "string", "format": "date" },
          "refs": { "type": "array", "items": { "type": "string" } },
          "scope": { "type": "array", "items": { "type": "string" } },
          "exclude": { "type": "array", "items": { "type": "string" } },
          "note": { "type": "string" }
        }
      }
    }
  }
}
