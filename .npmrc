# Per ADR-022 §Decision row 1: isolated linker is required for two-ABI native bindings
# (Electron renderer + Node 22 daemon must hold distinct compiled binaries of better-sqlite3).
# Hoisted layouts collapse this distinction and break one runtime or the other.
node-linker=isolated

# Pnpm telemetry / Turborepo telemetry opt-out per ADR-022 (Turbo) and good-citizen default.
# Turborepo telemetry is also disabled at workflow level via TURBO_TELEMETRY_DISABLED=1.

# Strict build-script policy — only allowlisted packages may run install-time scripts.
# Allowlist itself lives in `pnpm-workspace.yaml` under `allowBuilds:` (pnpm 10.26+; replaces
# deprecated `pnpm.onlyBuiltDependencies` / `ignoredBuiltDependencies` per pnpm.io/settings).
strict-dep-builds=true

# Disable pnpm's side-effects cache. The cache stores postinstall outputs (e.g. better-sqlite3's
# downloaded prebuild at `build/Release/better_sqlite3.node`) keyed by package version + platform
# but NOT by Node ABI (`process.versions.modules`); see pnpm/pnpm#5002 (open). On CI the daemon
# Node 22 (NODE_MODULE_VERSION 127) and control-plane Node 24 (NODE_MODULE_VERSION 137) jobs run
# in parallel against the same actions/setup-node@v5 pnpm-store cache (lockfile-keyed only —
# actions/setup-node#641), so whichever job's postinstall lands first wins and the loser reads
# back a wrong-ABI binding ⇒ "Module did not self-register". Disabling the side-effects cache
# forces `prebuild-install` to re-run per node_modules tree, picking the matching ABI prebuild
# every time. `pnpm rebuild` does NOT bypass the side-effects cache, so this flag — not a CI
# rebuild step — is the correct primitive.
side-effects-cache=false
